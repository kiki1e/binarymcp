# BinaryMCP Backend — Environment Variables
# 复制为 .env.backend 并按需修改

# ── GitHub 扫描 (保留 apicheck 功能) ──
# 多个 Token 用逗号分隔, 用于轮转防限流
GITHUB_TOKENS=ghp_your_token_1,ghp_your_token_2

# GitHub 事件轮询间隔 (秒)
POLL_INTERVAL=30

# ── 认证 ──
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
JWT_EXPIRE_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── 数据库 ──
DATABASE_URL=sqlite+aiosqlite:///./data/binarymcp.db

# ── 日志 ──
LOG_LEVEL=INFO
