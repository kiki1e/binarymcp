# PwnMCP Kiki1e - Environment Variables
# Copy this file to .env and modify as needed.

# --- Web Service Configuration ---
# The host IP address to bind the web service to.
# 0.0.0.0 means it will be accessible from outside the container/machine.
HOST=0.0.0.0

# The main port for the MCP service.
MCP_PORT=5500

# The port for the additional API.
API_PORT=5501

# --- Logging Configuration ---
# Log level for the application. Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Feature Flags ---
# Set to true to enable deep static analysis features (e.g., Rizin)
ENABLE_DEEP_STATIC=true

# Set to true to enable the RetDec decompiler (if installed)
ENABLE_RETDEC=false

# --- Paths ---
# The directory for storing analysis files, binaries, etc.
# This should match the volume mount in docker-compose.yml
WORKSPACE_DIR=/workspace

# Set by Docker automatically, no need to change
PYTHONUNBUFFERED=1
